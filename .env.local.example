# Copy this file to .env.local and fill in your Supabase project credentials
# (Project Settings -> API in the Supabase dashboard).
# .env.local is gitignored — never commit real keys.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Lead notification emails (optional — form works without, emails are skipped).
# Get an API key at resend.com -> API Keys.
RESEND_API_KEY=re_your_api_key
# Defaults to damyanzagorski@gmail.com if unset:
# LEAD_NOTIFY_TO=you@example.com
# Use Resend's onboarding sender until your domain is verified in Resend,
# then switch to e.g. "Electric Yacht Market <leads@electricyachtmarket.com>":
# LEAD_NOTIFY_FROM=Electric Yacht Market <onboarding@resend.dev>
